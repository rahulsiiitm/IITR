# Paths (relative to project root)
PDF_PATH=data/raw/phd_regulations_2026.pdf
VECTOR_DB_DIR=vector_db

# Models
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
RERANK_MODEL=BAAI/bge-reranker-base
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M

# If running Docker on Windows/Mac, use host.docker.internal
# If running without Docker on Linux, use localhost
OLLAMA_URL=http://host.docker.internal:11434/api/chat

# Retrieval
TOP_K=15
SUBQUESTION_TOP_K=6
RERANK_TOP_K=6
RERANK_TOP_K_MULTI=8
CHUNK_SIZE=2000
CHUNK_OVERLAP=250
CONFIDENCE_THRESHOLD=-5.0

# Server
API_PORT=45123
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080,http://127.0.0.1:5500,http://localhost:5500
API_KEY=your_secure_api_key_here
